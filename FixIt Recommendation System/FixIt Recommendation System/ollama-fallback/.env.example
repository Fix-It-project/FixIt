# ═══════════════════════════════════════════════════
#  FixIt Ollama Fallback — Environment Variables
#  Copy to .env and update values for your setup
# ═══════════════════════════════════════════════════

# Ollama API URL (WSL2 default)
# If Ollama runs on WSL2 and this server runs on Windows,
# use localhost if Ollama is port-forwarded, or the WSL2 IP.
OLLAMA_URL=http://localhost:11434

# Ollama model to use
OLLAMA_MODEL=gemma3:4b

# FixIt Recommendation API URL
FIXIT_API_URL=http://localhost:8000

# This server's port
PORT=3001

# Request timeout in milliseconds
OLLAMA_TIMEOUT_MS=120000

# Maximum tool-call loop iterations (safety limit)
MAX_TOOL_ITERATIONS=5
