{
	"name": "FixIt",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:admin": "turbo -F admin dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @FixIt/db db:push",
		"db:studio": "turbo -F @FixIt/db db:studio",
		"db:generate": "turbo -F @FixIt/db db:generate",
		"db:migrate": "turbo -F @FixIt/db db:migrate",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@FixIt/env": "workspace:*",
		"@codegenie/serverless-express": "^5.0.0",
		"dotenv": "catalog:",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@FixIt/config": "workspace:*",
		"@biomejs/biome": "^2.4.2",
		"@rolldown/binding-win32-x64-msvc": "1.0.0-rc.16",
		"@types/node": "catalog:",
		"dependency-cruiser": "^17.3.10",
		"pino-pretty": "^13.1.3",
		"turbo": "^2.8.9",
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"overrides": {
			"chokidar@>=5": "^4.0.3"
		}
	},
	"version": "0.4.0"
}
