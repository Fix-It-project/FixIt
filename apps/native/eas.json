{
	"cli": {
		"version": ">= 18.4.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"channel": "development",
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"APP_VARIANT": "development"
			}
		},
		"preview": {
			"channel": "preview",
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"SENTRY_DISABLE_AUTO_UPLOAD": "true",
				"SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
			}
		},
		"production": {
			"channel": "production",
			"autoIncrement": true,
			"env": {
				"SENTRY_DISABLE_AUTO_UPLOAD": "true",
				"SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
