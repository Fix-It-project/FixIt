{
	"cli": {
		"version": ">= 18.4.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal",
			"env": {
				"SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
			}
		},
		"production": {
			"autoIncrement": true,
			"env": {
				"SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
